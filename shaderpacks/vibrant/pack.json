{
  "name": "Vibrant",
  "version": "2.1",
  "settings": [
    {"key":"SHADOW_QUALITY","type":"int","min":0,"max":3,"default":2,"label":"Sun Shadow Quality"},
    {"key":"SHADOW_DARKNESS","type":"float","min":0.0,"max":1.0,"step":0.05,"default":0.5,"label":"Shadow Darkness"},
    {"key":"VOLUMETRIC","type":"bool","default":true,"label":"Volumetric Lighting"},
    {"key":"VL_QUALITY","type":"int","min":1,"max":3,"default":2,"label":"Volumetric Quality"},
    {"key":"VL_STRENGTH","type":"float","min":0.0,"max":2.0,"step":0.05,"default":0.8,"label":"Volumetric Strength"},
    {"key":"BLOOM","type":"bool","default":true,"label":"Bloom"},
    {"key":"BLOOM_STRENGTH","type":"float","min":0.0,"max":1.5,"step":0.05,"default":0.45,"label":"Bloom Strength"},
    {"key":"SATURATION","type":"float","min":0.0,"max":2.0,"step":0.05,"default":1.25,"label":"Saturation"},
    {"key":"CONTRAST","type":"float","min":0.5,"max":1.8,"step":0.05,"default":1.1,"label":"Contrast"},
    {"key":"EXPOSURE","type":"float","min":0.5,"max":2.0,"step":0.05,"default":1.15,"label":"Exposure"},
    {"key":"VIGNETTE","type":"float","min":0.0,"max":1.0,"step":0.05,"default":0.3,"label":"Vignette"},
    {"key":"SUN_GRADE","type":"float","min":0.0,"max":1.0,"step":0.05,"default":0.5,"label":"Sun Grading"},
    {"key":"HAZE","type":"float","min":0.0,"max":1.0,"step":0.05,"default":0.4,"label":"Haze"}
  ],
  "programs": {
    "bright": {"stage":"post","vsh":"shaders/composite.vsh","fsh":"shaders/bright.fsh"},
    "volumetric": {"stage":"post","vsh":"shaders/composite.vsh","fsh":"shaders/volumetric.fsh"},
    "composite": {"stage":"post","vsh":"shaders/composite.vsh","fsh":"shaders/composite.fsh"}
  },
  "targets": {
    "colortex0": {"format":"RGBA16F","scale":1.0},
    "bloomtex": {"format":"RGBA16F","scale":0.5},
    "vltex": {"format":"RGBA16F","scale":0.5}
  },
  "passes": [
    {"name":"bright","type":"post","program":"bright","inputs":["colortex0"],"output":"bloomtex"},
    {"name":"volumetric","type":"post","program":"volumetric","inputs":["depthtex0"],"output":"vltex"},
    {"name":"final","type":"post","program":"composite","inputs":["colortex0","depthtex0","bloomtex","vltex"],"output":"screen"}
  ]
}
