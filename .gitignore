```gitignore
# Compiled files
*.o
*.obj
*.out

# Dependencies
mods/*/lib/
mods/*/dependencies/
mods/*/build/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
build/
dist/
target/
*.class
*.pyc
__pycache__/
*.so
*.dll
*.exe

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
.julia/
.zig/

# Virtual environments
.venv/
venv/
env/
```